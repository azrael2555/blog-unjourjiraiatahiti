---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog - Un jour j'irai à Tahiti" description="Conseils, guides et inspiration pour voyager en Polynésie française">
  <section style="text-align:center; padding: 3rem 0 2rem;">
    <h1 style="font-size:2.2rem; color:#1a3a5c;">Blog Polynésie</h1>
    <p style="color:#666; margin-top:0.5rem;">Conseils, guides et inspiration pour préparer votre voyage</p>
  </section>

  <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px,1fr)); gap:2rem; margin-top:2rem;">
    {posts.map(post => (
      <a href={`/blog/${post.slug}`} style="text-decoration:none;">
        <article style="border:1px solid #e0e0e0; border-radius:12px; overflow:hidden; transition:transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='none'">
          {post.data.image && <img src={post.data.image} alt={post.data.title} style="width:100%; height:180px; object-fit:cover;" />}
          <div style="padding:1.2rem;">
            <h2 style="font-size:1.1rem; color:#1a3a5c;">{post.data.title}</h2>
            <p style="color:#666; font-size:0.9rem; margin-top:0.5rem;">{post.data.description}</p>
            <p style="color:#999; font-size:0.8rem; margin-top:0.8rem;">{new Date(post.data.date).toLocaleDateString('fr-FR')}</p>
          </div>
        </article>
      </a>
    ))}
  </div>
</Layout>
